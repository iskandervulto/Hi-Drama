# Copy this file to .env.local and fill in your Sanity project details
# Get these from sanity.io after creating a project

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# YouTube Data API v3 — for the /show page
# Get an API key at console.cloud.google.com → enable YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here
# Your channel ID (found in YouTube Studio → Settings → Channel → Advanced)
YOUTUBE_CHANNEL_ID=your_channel_id_here
